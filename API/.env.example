# ============================================
# Infinite-Canvas Automation API 配置模板
# ============================================
#
# 使用方法：
#   1. 复制此文件：  cp API/.env.example API/.env
#   2. 填写真实凭据（绝不要提交 .env 到 git）
#   3. 重启服务使配置生效
#
# ⚠️ 重要安全规则：
#   - API/.env 已在 .gitignore 中被忽略
#   - 永远不要把 .env 文件提交到任何 git 仓库
#   - 永远不要在聊天/工单/截图里贴真实密钥
#   - 密钥泄露后请立即到对应平台轮换
# ============================================

# ----- ModelScope 模型列表 -----
# 格式：provider/model[:displayName]，多个用英文逗号分隔
# 在网页左下角的"API 设置 → 模型列表"中可调整；此处作为后端默认值
# MODELSCOPE_CHAT_MODELS=Qwen/Qwen3-235B-A22B,Qwen/Qwen3-VL-235B-A22B-Instruct

# ----- Agnes AI 图文模型 -----
# 用于图像生成/编辑。注册：https://agnes-ai.example/ (具体见 README)
# API_PROVIDER_AGNES_AI_KEY=sk-your-agnes-ai-key-here

# ----- 自定义第三方 OpenAI 协议端点 -----
# 用于"通用 API 模式"，需配合 base_url 配置使用
# API_PROVIDER_CUSTOM_API_KEY=sk-your-custom-provider-key-here

# ----- LLM 输出上限 -----
# 单次 chat completion 最大 token 数；超过会被截断
# 推荐：4096 (短文) / 8192 (中等) / 16384 (长文/结构化)
LLM_MAX_TOKENS=16384


